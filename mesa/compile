#!/bin/sh -eux

# vulkan-overlay-layer: https://github.com/KhronosGroup/glslang

ub_compile \
	-Dplatforms=x11,wayland \
	-Ddri3=enabled \
	-Dgles1=disabled \
	-Dgles2=enabled \
	-Dgbm=enabled \
	-Dglx=dri \
	-Degl=enabled \
	-Dgallium-drivers=auto \
	-Dglvnd=enabled \
	-Dvulkan-drivers=amd,intel \
	-Dvulkan-layers=device-select,intel-nullhw,overlay \
	-Dllvm=enabled \
	-Dintel-clc=enabled \
	-Dlibunwind=enabled \
	-Dlmsensors=enabled \
	-Dtools=all \
	-Db_ndebug=true \
	-Db_lto=true \
	-Dvideo-codecs=all
