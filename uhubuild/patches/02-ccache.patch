From d8712064b5324ed81207c39fd2468c9869a416b7 Mon Sep 17 00:00:00 2001
From: rezso <rezso@rezso.net>
Date: Sun, 24 Jan 2021 21:25:57 +0100
Subject: [PATCH] disable ccache during configure

---
 src/helpers/ub_compile | 4 ++++
 src/helpers/ub_make    | 2 ++
 2 files changed, 6 insertions(+)

diff --git a/src/helpers/ub_compile b/src/helpers/ub_compile
index 761857c..6991345 100755
--- a/src/helpers/ub_compile
+++ b/src/helpers/ub_compile
@@ -1,5 +1,9 @@
 #!/bin/bash -eu
 
+# a ccache bezavarhat a configure lépésnél
+# pl. webkit2gtk nem találja a pthread.h-t
+export DISABLE_CCACHE=1
+
 if [ -f meson.build ]; then
 	argv=()
 	argx=(
diff --git a/src/helpers/ub_make b/src/helpers/ub_make
index 3d68e17..b9512da 100755
--- a/src/helpers/ub_make
+++ b/src/helpers/ub_make
@@ -4,6 +4,8 @@
 
 j="-j${UB_MAKE_PROCS:-$(_procs)}"
 
+export DISABLE_CCACHE=0
+
 if [ -f meson.build -a -f build/build.ninja ]; then
 	echo "ninja $j"
 	for i in "$@"; do
